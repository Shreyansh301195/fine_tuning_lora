# ─────────────────────────────────────────────────────────────
#  Copy this file to .env and fill in your values
#  $ cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── HuggingFace ──────────────────────────────────────────────
# Get your token at: https://huggingface.co/settings/tokens
# Accept Gemma license at: https://huggingface.co/google/gemma-3-1b-it
HF_TOKEN=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

# ── Model Config ─────────────────────────────────────────────
BASE_MODEL_ID=google/gemma-3-1b-it

# ── LoRA Hyperparameters ─────────────────────────────────────
LORA_R=8
LORA_ALPHA=16
LORA_DROPOUT=0.05
TARGET_MODULES=q_proj,k_proj,v_proj,o_proj,gate_proj,up_proj,down_proj

# ── Training Hyperparameters ─────────────────────────────────
BATCH_SIZE=4
GRAD_ACCUM_STEPS=4
NUM_EPOCHS=3
LEARNING_RATE=0.0003
MAX_SEQ_LEN=512
WARMUP_STEPS=50
EVAL_STEPS=50
SAVE_STEPS=100

# ── Backend Selection ─────────────────────────────────────────
# "mlx" for Apple Silicon (recommended), "hf" for HuggingFace PEFT
TRAINING_BACKEND=mlx

# ── LLM-as-a-Judge (Ollama — local, NO API KEY NEEDED) ───────
#
# Ollama runs open-source LLMs locally on your Mac.
# It exposes an OpenAI-compatible REST API at localhost:11434.
#
# Setup (one time):
#   brew install ollama          # install Ollama
#   ollama serve                 # start the server (keep running)
#   ollama pull llama3.2:3b      # download default judge model (~2 GB)
#
# Alternative judge models (pick based on your RAM budget):
#   ollama pull gemma3:4b        # same family as fine-tuned model (~3 GB)
#   ollama pull mistral:7b       # stronger reasoning (~4 GB)
#   ollama pull qwen2.5:7b       # excellent instruction-following (~4 GB)

OLLAMA_BASE_URL=http://localhost:11434/v1
JUDGE_MODEL=llama3.2:3b
JUDGE_MAX_SAMPLES=10

# ── Paths ─────────────────────────────────────────────────────
DATA_DIR=./data
ADAPTER_DIR=./adapters
LOG_DIR=./logs
