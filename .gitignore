__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/

# ── Secrets (NEVER commit these) ─────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ── Python packaging ──────────────────────────────────────────
*.egg-info/
dist/
build/
.eggs/

# ── Data files (generated, can be large) ─────────────────────
data/raw/          # downloaded PDFs
data/processed/    # extracted text
data/train/*.jsonl # generated training datasets
data/train/*.yaml  # generated MLX config files
data/train/*.json

# Keep empty directory markers
!data/.gitkeep
!data/raw/.gitkeep
!data/train/.gitkeep

# ── Model adapter weights (can be GBs) ───────────────────────
adapters/
!adapters/.gitkeep

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log

# ── macOS ─────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── IDEs ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── HuggingFace / MLX caches ─────────────────────────────────
.cache/
